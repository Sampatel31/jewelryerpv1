<Window x:Class="GoldSystem.WPF.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:GoldSystem.WPF.ViewModels"
        mc:Ignorable="d"
        Title="Gold Jewellery Management System"
        Height="768" Width="1366"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{materialDesign:MaterialDesignFont}"
        d:DataContext="{d:DesignInstance vm:ShellViewModel}">

    <!-- Keyboard shortcuts -->
    <Window.InputBindings>
        <KeyBinding Key="F1" Command="{Binding NavigateToDashboardCommand}" />
        <KeyBinding Key="F2" Command="{Binding NavigateToBillingCommand}" />
        <KeyBinding Key="F3" Command="{Binding NavigateToInventoryCommand}" />
        <KeyBinding Key="F4" Command="{Binding NavigateToCustomersCommand}" />
        <KeyBinding Key="F5" Command="{Binding NavigateToGoldRatesCommand}" />
        <KeyBinding Key="F6" Command="{Binding NavigateToReportsCommand}" />
        <KeyBinding Key="B" Modifiers="Control" Command="{Binding ToggleSidebarCommand}" />
        <KeyBinding Key="T" Modifiers="Control" Command="{Binding ToggleThemeCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ══ Header Bar ══════════════════════════════════════════════════════ -->
        <materialDesign:ColorZone Grid.Row="0"
                                   Mode="PrimaryDark"
                                   Padding="8,4"
                                   materialDesign:ElevationAssist.Elevation="Dp4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar toggle -->
                <Button Grid.Column="0"
                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                        Command="{Binding ToggleSidebarCommand}"
                        ToolTip="Toggle sidebar (Ctrl+B)"
                        Foreground="White">
                    <materialDesign:PackIcon Kind="Menu" Width="24" Height="24" />
                </Button>

                <!-- App title -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Diamond" Width="28" Height="28"
                                             Foreground="#FFD700"
                                             VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Gold Jewellery ERP"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Foreground="White"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Current page label -->
                <TextBlock Grid.Column="2"
                           Text="{Binding SelectedMenuItem}"
                           Style="{StaticResource MaterialDesignBody1TextBlock}"
                           Foreground="#CCFFFFFF"
                           VerticalAlignment="Center"
                           Margin="16,0" />

                <!-- Live Gold Rates -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <materialDesign:PackIcon Kind="Gold" Width="16" Height="16"
                                             Foreground="#FFD700"
                                             VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding AppState.Rate22KDisplay}"
                               Foreground="#FFD700"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <TextBlock Text="{Binding AppState.Rate24KDisplay}"
                               Foreground="#FFEC80"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Theme toggle -->
                <Button Grid.Column="4"
                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                        Command="{Binding ToggleThemeCommand}"
                        ToolTip="Toggle dark/light theme (Ctrl+T)"
                        Foreground="White"
                        Margin="4,0">
                    <materialDesign:PackIcon Kind="ThemeLightDark" Width="20" Height="20" />
                </Button>

                <!-- Branch label -->
                <Border Grid.Column="5"
                        Background="#33FFFFFF"
                        CornerRadius="4"
                        Padding="8,4"
                        Margin="4,2">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="StoreFront" Width="14" Height="14"
                                                 Foreground="White"
                                                 VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding AppState.CurrentBranchName}"
                                   Foreground="White"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </materialDesign:ColorZone>

        <!-- ══ Body: Sidebar + Content ════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <materialDesign:ColorZone Grid.Column="0"
                                       Mode="Standard"
                                       materialDesign:ElevationAssist.Elevation="Dp2">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Width="{Binding IsSidebarExpanded, Converter={StaticResource BoolToWidthConverter}}"
                                Margin="0,8">

                        <!-- Dashboard -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToDashboardCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=Dashboard}"
                                     ToolTip="Dashboard (F1)">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ViewDashboard" Width="22" Height="22" />
                                <TextBlock Text="Dashboard" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                        <!-- Billing -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToBillingCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=Billing}"
                                     ToolTip="Billing (F2)">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Receipt" Width="22" Height="22" />
                                <TextBlock Text="Billing" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                        <!-- Inventory -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToInventoryCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=Inventory}"
                                     ToolTip="Inventory (F3)">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Storefront" Width="22" Height="22" />
                                <TextBlock Text="Inventory" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                        <!-- Customers -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToCustomersCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=Customers}"
                                     ToolTip="Customers (F4)">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountGroup" Width="22" Height="22" />
                                <TextBlock Text="Customers" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                        <!-- Gold Rates -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToGoldRatesCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=Gold Rates}"
                                     ToolTip="Gold Rates (F5)">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CurrencyUsd" Width="22" Height="22" />
                                <TextBlock Text="Gold Rates" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                        <!-- Reports -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToReportsCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=Reports}"
                                     ToolTip="Reports (F6)">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ChartBar" Width="22" Height="22" />
                                <TextBlock Text="Reports" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                        <!-- Separator -->
                        <Separator Margin="8,4" />

                        <!-- AI Insights -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToAIInsightsCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=AI Insights}"
                                     ToolTip="AI Insights">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Brain" Width="22" Height="22" />
                                <TextBlock Text="AI Insights" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                        <!-- Vendors -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToVendorsCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=Vendors}"
                                     ToolTip="Vendors">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TruckDelivery" Width="22" Height="22" />
                                <TextBlock Text="Vendors" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                        <!-- Categories -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToCategoriesCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=Categories}"
                                     ToolTip="Categories">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Tag" Width="22" Height="22" />
                                <TextBlock Text="Categories" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                        <!-- Separator -->
                        <Separator Margin="8,4" />

                        <!-- Sync Status -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToSyncStatusCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=Sync Status}"
                                     ToolTip="Sync Status">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Sync" Width="22" Height="22" />
                                <TextBlock Text="Sync" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                        <!-- Audit Log -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToAuditLogCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=Audit Log}"
                                     ToolTip="Audit Log">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="History" Width="22" Height="22" />
                                <TextBlock Text="Audit Log" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                        <!-- Users -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToUserManagementCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=Users}"
                                     ToolTip="User Management">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountCog" Width="22" Height="22" />
                                <TextBlock Text="Users" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                        <!-- Branches -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToBranchesCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=Branches}"
                                     ToolTip="Branch Management">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="OfficeBuildingMarker" Width="22" Height="22" />
                                <TextBlock Text="Branches" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                        <!-- Settings -->
                        <RadioButton Style="{StaticResource MaterialDesignNavigationRailButton}"
                                     Command="{Binding NavigateToSettingsCommand}"
                                     IsChecked="{Binding SelectedMenuItem, Converter={StaticResource MenuItemMatchConverter}, ConverterParameter=Settings}"
                                     ToolTip="Settings">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Cog" Width="22" Height="22" />
                                <TextBlock Text="Settings" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </RadioButton>

                    </StackPanel>
                </ScrollViewer>
            </materialDesign:ColorZone>

            <!-- Main Content Area -->
            <ContentControl x:Name="ContentArea"
                            Grid.Column="1"
                            Margin="0" />
        </Grid>

        <!-- ══ Status Bar ═════════════════════════════════════════════════════ -->
        <StatusBar Grid.Row="2"
                   Background="{DynamicResource MaterialDesignDarkBackground}">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="{Binding StatusIndicator.SyncStatusIcon}"
                                             Width="14" Height="14"
                                             Foreground="#FFD700"
                                             VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding StatusIndicator.SyncStatus}"
                               Foreground="#CCFFFFFF"
                               FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding AppState.CurrentUserName, StringFormat='User: {0}'}"
                           Foreground="#AAFFFFFF"
                           FontSize="11" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
