<UserControl x:Class="GoldSystem.WPF.Views.BillingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:GoldSystem.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:BillingViewModel}"
             Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header bar -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
            <RowDefinition Height="*"/>      <!-- Main content -->
            <RowDefinition Height="Auto"/>   <!-- Bottom action bar -->
        </Grid.RowDefinitions>

        <!-- ══ 0. Header ════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Receipt" Width="28" Height="28"
                                         Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="New Bill"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Live rate pill -->
            <Border Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="#1AFFD700" CornerRadius="12" Padding="12,4">
                <TextBlock Text="{Binding CurrentRateDisplay}"
                           FontSize="12" FontWeight="SemiBold" Foreground="#FFD700"/>
            </Border>

            <!-- New Bill button (top right) -->
            <Button Grid.Column="2" Command="{Binding NewBillCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,4,0"/>
                    <TextBlock Text="New Bill"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ══ 1. Status bar ════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Margin="0,0,0,8" CornerRadius="4" Padding="10,6"
                Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#1A4CAF50"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasError}" Value="True">
                            <Setter Property="Background" Value="#1AF44336"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center">
                    <materialDesign:PackIcon.Style>
                        <Style TargetType="materialDesign:PackIcon">
                            <Setter Property="Kind" Value="CheckCircle"/>
                            <Setter Property="Foreground" Value="#4CAF50"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter Property="Kind" Value="AlertCircle"/>
                                    <Setter Property="Foreground" Value="#F44336"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </materialDesign:PackIcon.Style>
                </materialDesign:PackIcon>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- ══ 2. Main 3-column layout ═══════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>  <!-- Left: customer + scan -->
                <ColumnDefinition Width="*"/>    <!-- Centre: items DataGrid -->
                <ColumnDefinition Width="280"/>  <!-- Right: calculations + payment -->
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT PANEL ─────────────────────────────────────────── -->
            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Customer card -->
                    <RowDefinition Height="Auto"/>  <!-- Scan card -->
                    <RowDefinition Height="*"/>     <!-- spacer -->
                </Grid.RowDefinitions>

                <!-- Customer selection card -->
                <materialDesign:Card Grid.Row="0" Margin="0,0,0,8"
                                     materialDesign:ElevationAssist.Elevation="Dp2"
                                     Padding="12">
                    <StackPanel>
                        <TextBlock Text="CUSTOMER" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Margin="0,0,0,8"/>

                        <Grid>
                            <TextBox x:Name="CustomerSearchBox"
                                     materialDesign:HintAssist.Hint="Search name or phone…"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchCustomersCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Grid>

                        <!-- Autocomplete dropdown -->
                        <Popup IsOpen="{Binding IsCustomerSearchOpen}"
                               PlacementTarget="{Binding ElementName=CustomerSearchBox}"
                               Placement="Bottom" StaysOpen="False"
                               Width="{Binding ActualWidth, ElementName=CustomerSearchBox}">
                            <Border Background="{DynamicResource MaterialDesignPaper}"
                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                    BorderThickness="1" MaxHeight="200">
                                <ListBox ItemsSource="{Binding CustomerSuggestions}"
                                         SelectedItem="{Binding SelectedCustomer}"
                                         MaxHeight="200">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"/>
                                                <TextBlock Text="{Binding Phone}" FontSize="10"
                                                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding SelectCustomerCommand}"
                                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=SelectedItem}"/>
                                    </ListBox.InputBindings>
                                </ListBox>
                            </Border>
                        </Popup>

                        <!-- Selected customer display -->
                        <Border Margin="0,8,0,0" CornerRadius="4" Padding="8"
                                Background="#1A4CAF50"
                                Visibility="{Binding SelectedCustomer, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedCustomer.Name}"
                                           FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="{Binding SelectedCustomer.Phone}"
                                           FontSize="11"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Barcode / Tag scanner card -->
                <materialDesign:Card Grid.Row="1"
                                     materialDesign:ElevationAssist.Elevation="Dp2"
                                     Padding="12">
                    <StackPanel>
                        <TextBlock Text="SCAN ITEM  (F8)" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="BarcodeBox"
                                     materialDesign:HintAssist.Hint="Tag / HUID / Barcode"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13" FontFamily="Consolas">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding ScanItemCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>

                            <Button Grid.Column="1" Margin="4,0,0,0"
                                    Command="{Binding ScanItemCommand}"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="Scan / Add item">
                                <materialDesign:PackIcon Kind="BarcodeScan" Width="20" Height="20"/>
                            </Button>
                        </Grid>

                        <!-- Scan result message -->
                        <TextBlock Text="{Binding ScanStatusMessage}"
                                   FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ScanStatusMessage[0]}" Value="✗">
                                            <Setter Property="Foreground" Value="#F44336"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ScanStatusMessage[0]}" Value="⚠">
                                            <Setter Property="Foreground" Value="#FF9800"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <!-- ─── CENTRE PANEL: Items DataGrid ──────────────────────── -->
            <materialDesign:Card Grid.Column="1"
                                 materialDesign:ElevationAssist.Elevation="Dp2"
                                 Margin="0,0,8,0"
                                 Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Grid header -->
                    <Border Grid.Row="0" Background="#FFD700" Padding="12,8">
                        <Grid>
                            <TextBlock Text="Bill Items" FontWeight="Bold" FontSize="13"
                                       Foreground="#212121" VerticalAlignment="Center"/>
                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="#212121" FontSize="11">
                                <Run Text="{Binding LineItems.Count, Mode=OneWay}"/>
                                <Run Text=" item(s)"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding LineItems}"
                              SelectedItem="{Binding SelectedLineItem}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              materialDesign:DataGridAssist.CellPadding="8 4 8 4"
                              materialDesign:DataGridAssist.ColumnHeaderPadding="8 6 8 6"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tag / HUID" Binding="{Binding PurityTagDisplay}" Width="120"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding ItemName}" Width="*"/>
                            <DataGridTextColumn Header="Gross (g)" Binding="{Binding GrossWeight, StringFormat=N3}" Width="75"/>
                            <DataGridTextColumn Header="Stone (g)" Binding="{Binding StoneWeight, StringFormat=N3}" Width="75"/>
                            <DataGridTextColumn Header="Net (g)" Binding="{Binding NetWeight, StringFormat=N3}" Width="70"/>
                            <DataGridTextColumn Header="Wastage (g)" Binding="{Binding WastageWeight, StringFormat=N3}" Width="85"/>
                            <DataGridTextColumn Header="Gold ₹" Binding="{Binding GoldValue, StringFormat='₹{0:N0}'}" Width="80"/>
                            <DataGridTextColumn Header="Making ₹" Binding="{Binding MakingAmount, StringFormat='₹{0:N0}'}" Width="80"/>
                            <DataGridTextColumn Header="Total ₹" Binding="{Binding LineTotal, StringFormat='₹{0:N0}'}" Width="85"/>
                            <DataGridTemplateColumn Header="" Width="44">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                Height="28" Width="28"
                                                Foreground="#F44336"
                                                Command="{Binding DataContext.RemoveLineItemCommand,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Remove item">
                                            <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding LineItems.Count, Converter={StaticResource ZeroToVisibilityConverter}}">
                        <materialDesign:PackIcon Kind="BarcodeScan" Width="48" Height="48"
                                                 Foreground="#33FFD700" HorizontalAlignment="Center"/>
                        <TextBlock Text="Scan a barcode or enter a tag number to add items"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   FontSize="12"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- ─── RIGHT PANEL: Calculations + Payment ───────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Calculation breakdown -->
                    <RowDefinition Height="Auto"/>  <!-- Payment mode -->
                    <RowDefinition Height="Auto"/>  <!-- Amount fields -->
                    <RowDefinition Height="*"/>     <!-- spacer -->
                </Grid.RowDefinitions>

                <!-- Calculation breakdown card -->
                <materialDesign:Card Grid.Row="0" Margin="0,0,0,8"
                                     materialDesign:ElevationAssist.Elevation="Dp2"
                                     Padding="12">
                    <StackPanel>
                        <TextBlock Text="CALCULATION" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                                <RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>

                            <!-- Row helper: left label -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Gold Value" FontSize="12" Margin="0,3"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding GoldValueTotal, StringFormat='₹{0:N0}'}"
                                       FontSize="12" Margin="0,3" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Making Charges" FontSize="12" Margin="0,3"/>
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding MakingAmountTotal, StringFormat='₹{0:N0}'}"
                                       FontSize="12" Margin="0,3" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Wastage" FontSize="12" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding WastageAmountTotal, StringFormat='₹{0:N0}'}"
                                       FontSize="12" Margin="0,3" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Stone Charges" FontSize="12" Margin="0,3"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding StoneChargeTotal, StringFormat='₹{0:N0}'}"
                                       FontSize="12" Margin="0,3" HorizontalAlignment="Right"/>

                            <!-- Divider -->
                            <Separator Grid.Row="4" Grid.ColumnSpan="2" Margin="0,4"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Sub-Total" FontWeight="Bold" FontSize="12" Margin="0,3"/>
                            <TextBlock Grid.Row="5" Grid.Column="1"
                                       Text="{Binding SubTotal, StringFormat='₹{0:N0}'}"
                                       FontWeight="Bold" FontSize="12" Margin="0,3" HorizontalAlignment="Right"/>

                            <!-- Discount -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Discount" FontSize="12" Margin="0,3" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="6" Grid.Column="1"
                                     materialDesign:HintAssist.Hint="0"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged}"
                                     Width="90" FontSize="12" HorizontalAlignment="Right" Margin="0,2"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="CGST + SGST" FontSize="12" Margin="0,3"/>
                            <TextBlock Grid.Row="7" Grid.Column="1"
                                       Text="{Binding Cgst, StringFormat='₹{0:N0}'}"
                                       FontSize="12" Margin="0,3" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Round Off" FontSize="12" Margin="0,3"/>
                            <TextBlock Grid.Row="8" Grid.Column="1"
                                       Text="{Binding RoundOff, StringFormat='{}{0:N2}'}"
                                       FontSize="12" Margin="0,3" HorizontalAlignment="Right"/>

                            <!-- Grand Total highlighted row -->
                            <Border Grid.Row="9" Grid.ColumnSpan="2"
                                    Background="#FFD700" CornerRadius="4"
                                    Margin="0,6,0,0" Padding="8,6">
                                <Grid>
                                    <TextBlock Text="GRAND TOTAL" FontWeight="Bold" FontSize="14"
                                               Foreground="#212121"/>
                                    <TextBlock Text="{Binding GrandTotal, StringFormat='₹{0:N2}'}"
                                               FontWeight="Bold" FontSize="14"
                                               Foreground="#212121" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Payment card -->
                <materialDesign:Card Grid.Row="1" Margin="0,0,0,8"
                                     materialDesign:ElevationAssist.Elevation="Dp2"
                                     Padding="12">
                    <StackPanel>
                        <TextBlock Text="PAYMENT" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
                                   Margin="0,0,0,8"/>

                        <!-- Payment mode buttons -->
                        <WrapPanel>
                            <RadioButton Content="Cash" Margin="2" GroupName="PayMode"
                                         IsChecked="{Binding SelectedPaymentMode, Converter={StaticResource EqualityConverter}, ConverterParameter=Cash}"
                                         Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"/>
                            <RadioButton Content="Card" Margin="2" GroupName="PayMode"
                                         IsChecked="{Binding SelectedPaymentMode, Converter={StaticResource EqualityConverter}, ConverterParameter=Card}"
                                         Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"/>
                            <RadioButton Content="UPI" Margin="2" GroupName="PayMode"
                                         IsChecked="{Binding SelectedPaymentMode, Converter={StaticResource EqualityConverter}, ConverterParameter=UPI}"
                                         Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"/>
                            <RadioButton Content="NEFT" Margin="2" GroupName="PayMode"
                                         IsChecked="{Binding SelectedPaymentMode, Converter={StaticResource EqualityConverter}, ConverterParameter=NEFT}"
                                         Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"/>
                            <RadioButton Content="Split" Margin="2" GroupName="PayMode"
                                         IsChecked="{Binding SelectedPaymentMode, Converter={StaticResource EqualityConverter}, ConverterParameter=Split}"
                                         Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"/>
                            <RadioButton Content="Gold Exch." Margin="2" GroupName="PayMode"
                                         IsChecked="{Binding SelectedPaymentMode, Converter={StaticResource EqualityConverter}, ConverterParameter=OldGoldExchange}"
                                         Style="{StaticResource MaterialDesignChoiceChipOutlineRadioButton}"/>
                        </WrapPanel>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Old Gold Exchange ₹"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     materialDesign:HintAssist.Hint="0.00"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding ExchangeValue, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12" Margin="4,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Amount Paid ₹"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     materialDesign:HintAssist.Hint="0.00"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding AmountPaid, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12" Margin="4,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Balance Due ₹"
                                       FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding BalanceDue, StringFormat='₹{0:N2}'}"
                                       FontWeight="Bold" FontSize="13"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="4,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PaymentStatus}" Value="Partial">
                                                <Setter Property="Foreground" Value="#FF9800"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PaymentStatus}" Value="Pending">
                                                <Setter Property="Foreground" Value="#F44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Status:"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                       Text="{Binding PaymentStatus}"
                                       FontWeight="Bold" FontSize="12"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PaymentStatus}" Value="Partial">
                                                <Setter Property="Foreground" Value="#FF9800"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PaymentStatus}" Value="Pending">
                                                <Setter Property="Foreground" Value="#F44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- ══ 3. Bottom action bar ═════════════════════════════════════════ -->
        <materialDesign:Card Grid.Row="3" Margin="0,8,0,0"
                             materialDesign:ElevationAssist.Elevation="Dp4"
                             Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Loading indicator -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="4" Margin="0,0,8,0"/>
                    <TextBlock Text="Processing…" VerticalAlignment="Center" FontSize="11"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                </StackPanel>

                <!-- Clear button -->
                <Button Grid.Column="1" Margin="4,0"
                        Command="{Binding ClearBillCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#F44336"
                        BorderBrush="#F44336">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" Margin="0,0,4,0"/>
                        <TextBlock Text="Clear"/>
                    </StackPanel>
                </Button>

                <!-- Save button -->
                <Button Grid.Column="2" Margin="4,0"
                        Command="{Binding SaveBillCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#4CAF50" BorderBrush="#4CAF50">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,4,0"/>
                        <TextBlock Text="Save Bill"/>
                    </StackPanel>
                </Button>

                <!-- Print button -->
                <Button Grid.Column="3" Margin="4,0"
                        Command="{Binding PrintBillCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#FFD700" BorderBrush="#FFD700" Foreground="#212121">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Printer" Width="16" Height="16" Margin="0,0,4,0"/>
                        <TextBlock Text="Print PDF"/>
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
