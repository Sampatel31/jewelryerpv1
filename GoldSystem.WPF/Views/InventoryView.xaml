<UserControl x:Class="GoldSystem.WPF.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:GoldSystem.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:InventoryViewModel}"
             Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <materialDesign:PackIcon Kind="Storefront" Width="28" Height="28"
                                     Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="Inventory Management"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="16,0,0,0"
                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                       VerticalAlignment="Center" FontSize="12"/>
        </StackPanel>

        <!-- KPI Cards (Tab 1 only) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12"
                    Visibility="{Binding SelectedTabIndex, Converter={StaticResource EqualToVisibilityConverter}, ConverterParameter=0}">
            <materialDesign:Card Padding="12,8" Margin="0,0,8,0" MinWidth="130"
                                  materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="In Stock" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    <TextBlock Text="{Binding InStockCount}" FontSize="22" FontWeight="Bold" Foreground="#4CAF50"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Padding="12,8" Margin="0,0,8,0" MinWidth="160"
                                  materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="Stock Value" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="#FFD700">
                        <Run Text="₹"/>
                        <Run Text="{Binding InStockValue, StringFormat=N0}"/>
                    </TextBlock>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Padding="12,8" Margin="0,0,8,0" MinWidth="130"
                                  materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="Aging (&gt;90d)" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    <TextBlock Text="{Binding AgingItemsCount}" FontSize="22" FontWeight="Bold" Foreground="#FF5722"/>
                </StackPanel>
            </materialDesign:Card>
        </StackPanel>

        <!-- Tab Control -->
        <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedTabIndex}"
                    Style="{StaticResource MaterialDesignFilledTabControl}">

            <!-- ── TAB 1: Items ── -->
            <TabItem Header="Items">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search / Filter toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,8,0,8">
                        <TextBox Width="200" Margin="0,0,8,0"
                                 materialDesign:HintAssist.Hint="Search HUID / Tag / Name"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <ComboBox Width="130" Margin="0,0,8,0"
                                  materialDesign:HintAssist.Hint="Status"
                                  ItemsSource="{Binding StatusFilters, Mode=OneTime}"
                                  SelectedItem="{Binding SelectedStatusFilter}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        <Button Content="Refresh" Command="{Binding LoadCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0"/>
                        <Button Content="Transfer →" ToolTip="Transfer selected item to another branch"
                                Command="{Binding SelectTransferItemCommand}"
                                CommandParameter="{Binding SelectedItem}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"/>
                    </StackPanel>

                    <!-- Items DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding FilteredItems}"
                              SelectedItem="{Binding SelectedItem}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserSortColumns="True"
                              materialDesign:DataGridAssist.CellPadding="8 4 8 4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tag No" Binding="{Binding TagNo}" Width="90"/>
                            <DataGridTextColumn Header="HUID" Binding="{Binding HUID}" Width="90"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Purity" Binding="{Binding Purity}" Width="60"/>
                            <DataGridTextColumn Header="Gross Wt" Width="80"
                                                Binding="{Binding GrossWeight, StringFormat={}{0:N3}g}"/>
                            <DataGridTextColumn Header="Net Wt" Width="70"
                                                Binding="{Binding NetWeight, StringFormat={}{0:N3}g}"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="100"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                            <DataGridTextColumn Header="Days in Stock" Binding="{Binding DaysInStock}" Width="100"/>
                            <DataGridTextColumn Header="Cost Price"
                                                Binding="{Binding CostPrice, StringFormat=₹{0:N0}}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ── TAB 2: Stock Transfers ── -->
            <TabItem Header="Stock Transfers">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <!-- Transfer history -->
                    <Grid Grid.Column="0" Margin="0,0,8,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Transfer History"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,8,0,8"/>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding TransferHistory}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  materialDesign:DataGridAssist.CellPadding="8 4 8 4">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tag No" Binding="{Binding TagNo}" Width="90"/>
                                <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="*"/>
                                <DataGridTextColumn Header="From" Binding="{Binding FromBranchName}" Width="100"/>
                                <DataGridTextColumn Header="To" Binding="{Binding ToBranchName}" Width="100"/>
                                <DataGridTextColumn Header="Time"
                                                    Binding="{Binding TransferredAt, StringFormat=dd-MM HH:mm}" Width="100"/>
                                <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- Transfer form panel -->
                    <materialDesign:Card Grid.Column="1" Padding="16"
                                          materialDesign:ElevationAssist.Elevation="Dp2">
                        <StackPanel>
                            <TextBlock Text="New Transfer"
                                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,12"/>

                            <ComboBox Margin="0,0,0,12"
                                      materialDesign:HintAssist.Hint="Select Item (InStock)"
                                      ItemsSource="{Binding TransferableItems}"
                                      SelectedItem="{Binding SelectedTransferItem}"
                                      DisplayMemberPath="TagNo"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                            <TextBlock Text="{Binding SelectedTransferItem.Name}"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                       Margin="0,0,0,8" FontSize="12"
                                       Visibility="{Binding SelectedTransferItem, Converter={StaticResource NullToVisibilityConverter}}"/>

                            <ComboBox Margin="0,0,0,12"
                                      materialDesign:HintAssist.Hint="Destination Branch"
                                      ItemsSource="{Binding Branches}"
                                      SelectedItem="{Binding SelectedDestinationBranch}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                            <TextBox Margin="0,0,0,12"
                                     materialDesign:HintAssist.Hint="Remarks (optional)"
                                     Text="{Binding TransferRemarks, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                            <Button Content="Transfer Item"
                                    Command="{Binding TransferItemCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#FFD700" Foreground="Black"
                                    IsEnabled="{Binding IsTransferring, Converter={StaticResource InverseBoolConverter}}"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
