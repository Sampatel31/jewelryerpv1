<UserControl x:Class="GoldSystem.WPF.Views.SecurityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:GoldSystem.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SecurityViewModel}"
             Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <materialDesign:PackIcon Kind="ShieldAccount" Width="32" Height="32"
                                     Foreground="#FFD700"
                                     VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Text="Security &amp; User Management"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 4-Tab Control -->
        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    Style="{StaticResource MaterialDesignTabControl}">

            <!-- ════════════════════════════════════════════════════════════════
                 TAB 1 – USER MANAGEMENT
                 ════════════════════════════════════════════════════════════════ -->
            <TabItem Header="Users">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountMultiple" Margin="0,0,6,0"/>
                            <TextBlock Text="Users"/>
                        </StackPanel>
                    </DataTemplate>
                </TabItem.HeaderTemplate>

                <Grid DataContext="{Binding UserManagement}" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Command="{Binding NewUserCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#FFD700" Foreground="Black" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountPlus" Margin="0,0,4,0"/>
                                <TextBlock Text="Add User"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding LoadCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" Margin="0,0,4,0"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- User Grid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Users}"
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              materialDesign:DataGridAssist.CellPadding="8 4 8 4"
                              Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"       Binding="{Binding Id}"          Width="50"/>
                            <DataGridTextColumn Header="Username" Binding="{Binding Username}"     Width="150"/>
                            <DataGridTextColumn Header="Email"    Binding="{Binding Email}"        Width="200"/>
                            <DataGridTextColumn Header="Role ID"  Binding="{Binding RoleId}"       Width="80"/>
                            <DataGridTextColumn Header="Status"   Binding="{Binding Status}"       Width="100"/>
                            <DataGridTextColumn Header="2FA"      Binding="{Binding TwoFactorEnabled}" Width="60"/>
                            <DataGridTextColumn Header="Last Login" Binding="{Binding LastLogin, StringFormat=dd-MMM-yyyy}" Width="120"/>
                            <DataGridTemplateColumn Header="Actions" Width="240">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Command="{Binding DataContext.EditUserCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="Edit" Margin="2,0">
                                                <materialDesign:PackIcon Kind="Pencil"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.ResetPasswordCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="Reset Password" Margin="2,0">
                                                <materialDesign:PackIcon Kind="LockReset"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.Toggle2FACommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    ToolTip="Toggle 2FA" Margin="2,0">
                                                <materialDesign:PackIcon Kind="TwoFactorAuthentication"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteUserCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    Foreground="Red" ToolTip="Delete" Margin="2,0">
                                                <materialDesign:PackIcon Kind="Delete"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Edit Form (visible when IsEditing = true) -->
                    <materialDesign:Card Grid.Row="2" Padding="16" Margin="0,0,0,8"
                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     materialDesign:HintAssist.Hint="Username"
                                     Text="{Binding FormUsername, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     materialDesign:HintAssist.Hint="Email"
                                     Text="{Binding FormEmail, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,8,0"/>
                            <PasswordBox Grid.Column="2"
                                         materialDesign:HintAssist.Hint="Password (leave blank to keep)"
                                         materialDesign:PasswordBoxAssist.Password="{Binding FormPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         Margin="0,0,8,0"/>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Command="{Binding SaveUserCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#FFD700" Foreground="Black" Margin="0,0,8,0"
                                        Content="Save"/>
                                <Button Command="{Binding CancelEditCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Content="Cancel"/>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!-- Status Bar -->
                    <TextBlock Grid.Row="3"
                               Text="{Binding StatusMessage}"
                               Foreground="{Binding HasError, Converter={StaticResource BoolToErrorBrushConverter}}"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                </Grid>
            </TabItem>

            <!-- ════════════════════════════════════════════════════════════════
                 TAB 2 – ROLE-BASED ACCESS CONTROL
                 ════════════════════════════════════════════════════════════════ -->
            <TabItem Header="Roles &amp; Permissions">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ShieldKey" Margin="0,0,6,0"/>
                            <TextBlock Text="RBAC"/>
                        </StackPanel>
                    </DataTemplate>
                </TabItem.HeaderTemplate>

                <Grid DataContext="{Binding RBAC}" Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Role List Panel -->
                    <DockPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Roles"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,8"/>

                        <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                            <TextBox materialDesign:HintAssist.Hint="New role name"
                                     Text="{Binding NewRoleName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,4"/>
                            <TextBox materialDesign:HintAssist.Hint="Description"
                                     Text="{Binding NewRoleDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,4"/>
                            <Button Command="{Binding CreateRoleCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#FFD700" Foreground="Black"
                                    Content="Create Role"/>
                        </StackPanel>

                        <ListBox ItemsSource="{Binding Roles}"
                                 SelectedItem="{Binding SelectedRole}"
                                 DisplayMemberPath="Name"/>
                    </DockPanel>

                    <!-- Permissions Matrix -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding SelectedRole.Name, StringFormat='Permissions for: {0}'}"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,8"/>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding PermissionMatrix}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  materialDesign:DataGridAssist.CellPadding="8 4 8 4">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Module"  Binding="{Binding ModuleName}" Width="120" IsReadOnly="True"/>
                                <DataGridCheckBoxColumn Header="View"   Binding="{Binding CanView}"   Width="70"/>
                                <DataGridCheckBoxColumn Header="Create" Binding="{Binding CanCreate}" Width="70"/>
                                <DataGridCheckBoxColumn Header="Edit"   Binding="{Binding CanEdit}"   Width="70"/>
                                <DataGridCheckBoxColumn Header="Delete" Binding="{Binding CanDelete}" Width="70"/>
                                <DataGridCheckBoxColumn Header="Print"  Binding="{Binding CanPrint}"  Width="70"/>
                                <DataGridCheckBoxColumn Header="Export" Binding="{Binding CanExport}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Grid.Row="2"
                                Command="{Binding SavePermissionsCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#FFD700" Foreground="Black"
                                HorizontalAlignment="Right" Margin="0,8,0,0"
                                IsEnabled="True">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" Margin="0,0,4,0"/>
                                <TextBlock Text="Save Permissions"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Grid.Row="3"
                                   Text="{Binding StatusMessage}"
                                   Margin="0,4,0,0"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ════════════════════════════════════════════════════════════════
                 TAB 3 – AUDIT TRAIL
                 ════════════════════════════════════════════════════════════════ -->
            <TabItem Header="Audit Trail">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="History" Margin="0,0,6,0"/>
                            <TextBlock Text="Audit"/>
                        </StackPanel>
                    </DataTemplate>
                </TabItem.HeaderTemplate>

                <Grid DataContext="{Binding AuditTrail}" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Filter Bar -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0"/>

                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding AvailableModules}"
                                  SelectedItem="{Binding FilterModule}"
                                  materialDesign:HintAssist.Hint="Module"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Margin="0,0,8,0"/>

                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding AvailableActions}"
                                  SelectedItem="{Binding FilterAction}"
                                  materialDesign:HintAssist.Hint="Action"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Margin="0,0,8,0"/>

                        <DatePicker Grid.Column="3"
                                    SelectedDate="{Binding FilterFrom}"
                                    materialDesign:HintAssist.Hint="From"
                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                    Margin="0,0,8,0"/>

                        <DatePicker Grid.Column="4"
                                    SelectedDate="{Binding FilterTo}"
                                    materialDesign:HintAssist.Hint="To"
                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                    Margin="0,0,8,0"/>

                        <Button Grid.Column="5"
                                Command="{Binding FilterLogsCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#FFD700" Foreground="Black" Margin="0,0,8,0"
                                Content="Search"/>

                        <Button Grid.Column="6"
                                Command="{Binding ExportExcelCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="Export CSV"/>
                    </Grid>

                    <!-- Log Grid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding AuditLogs}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              materialDesign:DataGridAssist.CellPadding="6 3 6 3">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"        Binding="{Binding Id}"                Width="60"/>
                            <DataGridTextColumn Header="User"      Binding="{Binding UserId}"            Width="70"/>
                            <DataGridTextColumn Header="Action"    Binding="{Binding Action}"            Width="160"/>
                            <DataGridTextColumn Header="Module"    Binding="{Binding Module}"            Width="100"/>
                            <DataGridTextColumn Header="Entity"    Binding="{Binding Entity}"            Width="100"/>
                            <DataGridTextColumn Header="Entity ID" Binding="{Binding EntityId}"          Width="80"/>
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding FormattedTimestamp}" Width="160"/>
                            <DataGridTextColumn Header="IP"        Binding="{Binding IpAddress}"         Width="120"/>
                            <DataGridTextColumn Header="Old Value" Binding="{Binding OldValue}"          Width="140"/>
                            <DataGridTextColumn Header="New Value" Binding="{Binding NewValue}"          Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Status Bar -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="{Binding TotalCount, StringFormat='{}{0} entries'}"/>
                        <TextBlock Text=" · "/>
                        <TextBlock Text="{Binding StatusMessage}"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ════════════════════════════════════════════════════════════════
                 TAB 4 – SECURITY SETTINGS
                 ════════════════════════════════════════════════════════════════ -->
            <TabItem Header="Security Settings">
                <TabItem.HeaderTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Security" Margin="0,0,6,0"/>
                            <TextBlock Text="Settings"/>
                        </StackPanel>
                    </DataTemplate>
                </TabItem.HeaderTemplate>

                <ScrollViewer DataContext="{Binding SecuritySettings}" VerticalScrollBarVisibility="Auto" Margin="16">
                    <StackPanel MaxWidth="700" HorizontalAlignment="Left">

                        <!-- Password Policy -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Password Policy"
                                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                           Margin="0,0,0,12"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBox Grid.Row="0" Grid.Column="0"
                                             materialDesign:HintAssist.Hint="Minimum Length"
                                             Text="{Binding PasswordMinLength}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Margin="0,0,8,8"/>
                                    <TextBox Grid.Row="0" Grid.Column="1"
                                             materialDesign:HintAssist.Hint="Expiry Days (0 = never)"
                                             Text="{Binding PasswordExpiryDays}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Margin="0,0,0,8"/>

                                    <CheckBox Grid.Row="1" Grid.Column="0"
                                              Content="Require Uppercase"
                                              IsChecked="{Binding RequireUppercase}"
                                              Margin="0,0,0,8"/>
                                    <CheckBox Grid.Row="1" Grid.Column="1"
                                              Content="Require Lowercase"
                                              IsChecked="{Binding RequireLowercase}"
                                              Margin="0,0,0,8"/>
                                    <CheckBox Grid.Row="2" Grid.Column="0"
                                              Content="Require Digits"
                                              IsChecked="{Binding RequireDigits}"
                                              Margin="0,0,0,8"/>
                                    <CheckBox Grid.Row="2" Grid.Column="1"
                                              Content="Require Special Characters"
                                              IsChecked="{Binding RequireSpecialChars}"
                                              Margin="0,0,0,8"/>
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Lockout Policy -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Account Lockout"
                                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                           Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             materialDesign:HintAssist.Hint="Max Failed Attempts"
                                             Text="{Binding MaxLoginAttempts}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1"
                                             materialDesign:HintAssist.Hint="Lockout Duration (minutes)"
                                             Text="{Binding LockoutDurationMinutes}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Session -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Session"
                                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                           Margin="0,0,0,12"/>
                                <TextBox materialDesign:HintAssist.Hint="Session Timeout (minutes)"
                                         Text="{Binding SessionTimeoutMinutes}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- 2FA -->
                        <materialDesign:Card Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Two-Factor Authentication"
                                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                           Margin="0,0,0,12"/>
                                <CheckBox Content="Require 2FA for all users"
                                          IsChecked="{Binding TwoFactorRequired}"
                                          Margin="0,0,0,8"/>
                                <ComboBox ItemsSource="{Binding TwoFactorMethods}"
                                          SelectedItem="{Binding DefaultTwoFactorMethod}"
                                          materialDesign:HintAssist.Hint="Default 2FA Method"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Command="{Binding SaveCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#FFD700" Foreground="Black" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSave" Margin="0,0,4,0"/>
                                    <TextBlock Text="Save Settings"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ResetToDefaultsCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Restore" Margin="0,0,4,0"/>
                                    <TextBlock Text="Reset Defaults"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,8,0,0"
                                   Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
