<UserControl x:Class="GoldSystem.WPF.Views.AIInsightsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:GoldSystem.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:AIInsightsViewModel}"
             Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
            <materialDesign:PackIcon Kind="Brain" Width="32" Height="32"
                                     Foreground="#FFD700"
                                     VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBlock Text="AI Insights"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <materialDesign:Card Grid.Row="1"
                              materialDesign:ElevationAssist.Elevation="Dp2"
                              Padding="24">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Brain" Width="64" Height="64"
                                         Foreground="#33FFD700"
                                         HorizontalAlignment="Center" />
                <TextBlock Text="AI Insights – Coming in Phase 10-11"
                           Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           Margin="0,16,0,0" />
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
