<UserControl x:Class="GoldSystem.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:GoldSystem.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             Background="{DynamicResource MaterialDesignPaper}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Loading overlay -->
            <Border Grid.Row="0"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                    HorizontalAlignment="Center" Margin="0,8">
                <StackPanel Orientation="Horizontal">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True"
                                 Width="24" Height="24" Margin="0,0,8,0" />
                    <TextBlock Text="Loading dashboard…"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ── Row 1: KPI Cards ──────────────────────────────────────────── -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Today's Sales -->
                <materialDesign:Card Grid.Column="0" Margin="0,0,8,0"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CurrencyInr" Width="20" Height="20"
                                                     Foreground="#FFD700" VerticalAlignment="Center" />
                            <TextBlock Text="Today's Sales" Margin="6,0,0,0"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
                        </StackPanel>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding TodaySales, StringFormat='₹{0:N0}'}"
                                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                   Foreground="#FFD700"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0" />
                        <TextBlock Grid.Row="2"
                                   Text="{Binding TodayBillCount, StringFormat='{}{0} bill(s)'}"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    </Grid>
                </materialDesign:Card>

                <!-- Month Sales -->
                <materialDesign:Card Grid.Column="1" Margin="4,0,8,0"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CalendarMonth" Width="20" Height="20"
                                                     Foreground="#4CAF50" VerticalAlignment="Center" />
                            <TextBlock Text="Month Sales" Margin="6,0,0,0"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
                        </StackPanel>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding MonthSales, StringFormat='₹{0:N0}'}"
                                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                   Foreground="#4CAF50"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0" />
                        <TextBlock Grid.Row="2"
                                   Text="{Binding MonthBillCount, StringFormat='{}{0} bill(s)'}"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    </Grid>
                </materialDesign:Card>

                <!-- Items In Stock -->
                <materialDesign:Card Grid.Column="2" Margin="4,0,8,0"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Storefront" Width="20" Height="20"
                                                     Foreground="#2196F3" VerticalAlignment="Center" />
                            <TextBlock Text="Items In Stock" Margin="6,0,0,0"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
                        </StackPanel>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding TotalItemsInStock}"
                                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                   Foreground="#2196F3"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0" />
                        <TextBlock Grid.Row="2"
                                   Text="{Binding LowStockAlerts, StringFormat='{}{0} low stock alert(s)'}"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    </Grid>
                </materialDesign:Card>

                <!-- Pending Sync -->
                <materialDesign:Card Grid.Column="3" Margin="4,0,8,0"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Sync" Width="20" Height="20"
                                                     Foreground="#FF9800" VerticalAlignment="Center" />
                            <TextBlock Text="Pending Sync" Margin="6,0,0,0"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
                        </StackPanel>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding PendingSyncCount}"
                                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                   Foreground="#FF9800"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0" />
                        <TextBlock Grid.Row="2" Text="records queued"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    </Grid>
                </materialDesign:Card>

                <!-- Current 22K Rate -->
                <materialDesign:Card Grid.Column="4" Margin="4,0,0,0"
                                      materialDesign:ElevationAssist.Elevation="Dp2"
                                      Background="#1AFFD700">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Gold" Width="20" Height="20"
                                                     Foreground="#FFD700" VerticalAlignment="Center" />
                            <TextBlock Text="22K Rate" Margin="6,0,0,0"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}" />
                        </StackPanel>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding AppState.Rate22KDisplay}"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                   Foreground="#FFD700"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0" />
                        <TextBlock Grid.Row="2"
                                   Text="{Binding AppState.RateSource}"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}" />
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <!-- ── Row 2: Charts ─────────────────────────────────────────────── -->
            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <materialDesign:Card Grid.Column="0" Margin="0,0,8,0"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="200" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="7-Day Sales Overview"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,8" />
                        <!-- Chart injected from code-behind -->
                        <ContentControl x:Name="SalesChartHost" Grid.Row="1" />
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="1" Margin="4,0,0,0"
                                      materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="200" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="30-Day Rate Trend (22K)"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Margin="0,0,0,8" />
                        <!-- Chart injected from code-behind -->
                        <ContentControl x:Name="RateChartHost" Grid.Row="1" />
                    </Grid>
                </materialDesign:Card>
            </Grid>

            <!-- ── Row 3: Quick Actions ──────────────────────────────────────── -->
            <materialDesign:Card Grid.Row="3"
                                  materialDesign:ElevationAssist.Elevation="Dp1"
                                  Margin="0,0,0,8">
                <StackPanel Margin="16">
                    <TextBlock Text="Quick Actions"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,12" />
                    <WrapPanel>
                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#FFD700"
                                Foreground="Black"
                                Margin="0,0,8,4"
                                Content="Refresh"
                                Command="{Binding LoadDataCommand}" />
                    </WrapPanel>
                </StackPanel>
            </materialDesign:Card>

        </Grid>
    </ScrollViewer>
</UserControl>
